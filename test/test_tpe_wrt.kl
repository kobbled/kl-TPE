PROGRAM test_tpe_wrt
%NOLOCKGROUP

%define TPP_WRITE_PROG 'new_prog'
%define TPP_WRITE_PROG2 'prog_del'
%define TEST_TPP_PROGRAM 'test_tpe_ls'
%define TEST_TPP_COPY 'test_tpe_crt'

%include tpe.klt

%include systemvars.klt
%include pathlib.klt
--add for motion depencencies
%include motion.deps.klt
%include toolpath.structs.klt
%include tpe.klt

-- define system dependent position type t_NODE
-- [!IMPORTANT] this must be defined in a template file
-- see test examples.
%include defaultrotpose.klt
%ifdef motion_type
motion_type(MOTION_DATA_FILE)
%endif

--tpe specific types
%include tpepose.general.type.klt

%include tpepose.system.type.klt
set_position_type(tsttpe)

VAR
  cart_poses : PATH nodedata = t_POSITION
  jnt_poses : PATH nodedata = t_JPOSITION
  motion_list : PATH nodedata = t_MOTIONSTAT
  scratch_fl : FILE

%include tpe.klh
%include files.klh
%include kunit.klh

%ifeq BUILD_ROBOT_INTERFACE TRUE
--define robot motion interface
robot_motion_define(MOTION_DATA_FILE,defaultrotpose.klt)
%else
-- Robot pose implementation header
impl_motion_head(MOTION_DATA_FILE)
%endif

%class tsttpe('tpepose.klc','tpepose.klh','defaultrotpose.klt')

--clear

ROUTINE clear_motion(p : PATH nodedata = t_MOTIONSTAT)
  VAR
    i, status : INTEGER
  BEGIN
    i = PATH_LEN(p)
    WHILE PATH_LEN(p) > 0 DO
		  DELETE_NODE(p,i,status)
      i = i - 1
	  ENDWHILE
  END clear_motion

ROUTINE clear_cart(p : PATH nodedata = t_POSITION)
  VAR
    i, status : INTEGER
  BEGIN
    i = PATH_LEN(p)
    WHILE PATH_LEN(p) > 0 DO
		  DELETE_NODE(p,i,status)
      i = i - 1
	  ENDWHILE
  END clear_cart

ROUTINE clear_joint(p : PATH nodedata = t_JPOSITION)
  VAR
    i, status : INTEGER
  BEGIN
    i = PATH_LEN(p)
    WHILE PATH_LEN(p) > 0 DO
		  DELETE_NODE(p,i,status)
      i = i - 1
	  ENDWHILE
  END clear_joint

ROUTINE clear_poses
  BEGIN
    clear_cart(cart_poses)
    clear_joint(jnt_poses)
    clear_motion(motion_list)
  END clear_poses

-- ********

BEGIN
  --clear data
  clear_poses


  --get data from LS file
  tpe__open(TEST_TPP_PROGRAM)
  tpe__open_file(TEST_TPP_PROGRAM)

  --fill struct for motions
  tsttpe__get_motion_statements(motion_list)

  --fill structs for positions
  tsttpe__get_cart_poses(TEST_TPP_PROGRAM, cart_poses)
  tsttpe__get_joint_poses(TEST_TPP_PROGRAM, jnt_poses)

  tpe__close_file
  tpe__close(TEST_TPP_PROGRAM)


  --create blank template
  tpe__create(TPP_WRITE_PROG)
  --change group mask
  set_tpe_groups(TPP_WRITE_PROG)

  --write to new LS file
  tpe__create_ls(TEST_TPP_COPY)
  tpe__copy_header_ls(TPP_WRITE_PROG)

  --insert program here
  tpe__write_pause

  --write end of file
  tpe__write_end

  --close ls file
  tpe__close_ls

  -- --add positions to new LS file
  -- set_tpe_poses(TPP_WRITE_PROG, cart_poses, jnt_poses)

  --### delete tests ###

  --tpe__delete on a nonexistent program should be silent
  tpe__delete('NO_SUCH')
  kunit_test('tpe__delete swallows missing file', TRUE)

  --tpe__delete on the just-created TPP_WRITE_PROG should remove the .TP
  tpe__delete(TPP_WRITE_PROG2)
  kunit_test('tpe__delete removes .TP', NOT tpe__ls_exists(TPP_WRITE_PROG))

  --tpe__delete should also work when the program is currently open
  tpe__create(TPP_WRITE_PROG2)
  tpe__open(TPP_WRITE_PROG2)
  tpe__delete(TPP_WRITE_PROG2)
  kunit_test('tpe__delete handles open program', NOT tpe__ls_exists(TPP_WRITE_PROG))

  --files__delete on a scratch file should not abort, and a second call
  --against the now-missing file is also safe
  files__create('MD:/TPESCRTCH.DT', scratch_fl)
  files__delete('MD:/TPESCRTCH.DT')
  files__delete('MD:/TPESCRTCH.DT')
  kunit_test('files__delete is idempotent', TRUE)

  --### wildcard delete tests ###

  --batch-create three programs sharing a prefix, then wipe with one wildcard call
  tpe__create('TMPS_DELP1')
  tpe__create('TMPS_DELP2')
  tpe__create('TMPS_DELP3')
  tpe__delete_pattern('TMPS_DELP*')
  kunit_test('tpe__delete_pattern removes TMPS_DELP1', NOT tpe__ls_exists('TMPS_DELP1'))
  kunit_test('tpe__delete_pattern removes TMPS_DELP2', NOT tpe__ls_exists('TMPS_DELP2'))
  kunit_test('tpe__delete_pattern removes TMPS_DELP3', NOT tpe__ls_exists('TMPS_DELP3'))

  --no-match wildcard should be silent (file-not-found status is swallowed)
  tpe__delete_pattern('NO_MATCH_PREFIX*')
  kunit_test('tpe__delete_pattern swallows no-match', TRUE)

  kunit_done

END test_tpe_wrt