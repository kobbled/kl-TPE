%ifndef tpe_types_t
%define tpe_types_t

%defeval TPE_DICTIONARY_FILENAME tpelog

-- TPEPROGRM struct body lives in hash_tpeprog.klt's hash_type_define macro.
-- Expand it here with TPE_DICTIONARY_FILENAME as the owning program so the
-- import-style declaration in this file stays in lock-step with the owning
-- declaration the hash class template emits inside tpelog.
%include hash_tpeprog.klt
hash_type_define(TPE_DICTIONARY_FILENAME)

%endif